# Enable Banking — register at https://enablebanking.com/cp/applications
# Create a "Production (Restricted)" application and download the .pem private key

# Application UUID (visible in the Control Panel)
EB_APP_ID=aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee

# Path to the .pem file downloaded during app registration
EB_PRIVATE_KEY_PATH=aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee.pem

# Bank to connect to — required for `bankfetch auth`.
# Run `bankfetch aspsps` to list all available names and two-letter country codes.
# Overridden by command-line arguments if provided.
EB_ASPSP_NAME=Bank Name
EB_ASPSP_COUNTRY=IT

# Optional (default values shown)
# EB_REDIRECT_URL=https://localhost/auth_redirect
# EB_SESSION_FILE=.session.json
